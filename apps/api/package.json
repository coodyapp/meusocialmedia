{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply meusocialmedia-db",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@meusocialmedia/types": "workspace:*",
    "@meusocialmedia/utils": "workspace:*",
    "hono": "^4.7.11",
    "drizzle-orm": "^0.44.2",
    "zod": "^3.25.28",
    "@hono/zod-validator": "^0.5.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.11",
    "@cloudflare/workers-types": "^4.20250525.0",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "wrangler": "^4.15.2"
  }
}
